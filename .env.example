# Frontend
VITE_API_URL=http://localhost:3000
# true keeps the current static in-memory frontend behavior.
# false enables HTTP synchronization with the backend API when available.
VITE_USE_MOCKS=true
VITE_WORKSPACE_ID=w1

# Backend
PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
DATABASE_URL=postgresql://agility:agility_dev@localhost:5432/agility?schema=public
# memory | prisma
DATA_STORE=memory
